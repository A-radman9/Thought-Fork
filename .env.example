# ==========================================
# THOUGHT FORK - API PROVIDER CONFIGURATION
# ==========================================
# Uncomment the block for the provider you want to use.

# ------------------------------------------
# OPTION 1: OLLAMA (Local)
# Requires Ollama running with: ollama run llama3
# ------------------------------------------
#THOUGHT_FORK_API_BASE=http://localhost:11434/v1
#THOUGHT_FORK_MODEL=llama3
#THOUGHT_FORK_SYNTHESIS_MODEL=llama3
#THOUGHT_FORK_SELECTOR_MODEL=llama3
# API Key is not required for local providers
#THOUGHT_FORK_API_KEY=ollama

# ------------------------------------------
# OPTION 2: LM STUDIO (Local)
# Requires LM Studio running its local server on port 1234
# ------------------------------------------
# THOUGHT_FORK_API_BASE=http://localhost:1234/v1
# THOUGHT_FORK_MODEL=local-model
# THOUGHT_FORK_SYNTHESIS_MODEL=local-model
# THOUGHT_FORK_SELECTOR_MODEL=local-model
# THOUGHT_FORK_API_KEY=lm-studio

# ------------------------------------------
# OPTION 3: GROQ (Cloud)
# ------------------------------------------
# THOUGHT_FORK_API_BASE=https://api.groq.com/openai/v1
# THOUGHT_FORK_MODEL=llama-3.3-70b-versatile
# THOUGHT_FORK_SYNTHESIS_MODEL=llama-3.3-70b-versatile
# THOUGHT_FORK_SELECTOR_MODEL=llama-3.3-70b-versatile
# THOUGHT_FORK_API_KEY=your-groq-api-key-here

# ------------------------------------------
# OPTION 4: AIONLABS (Cloud)
# ------------------------------------------
# THOUGHT_FORK_API_BASE=https://api.aionlabs.ai/v1
# THOUGHT_FORK_MODEL=aion-labs/aion-1.0-mini
# THOUGHT_FORK_SYNTHESIS_MODEL=aion-labs/aion-1.0-mini
# THOUGHT_FORK_SELECTOR_MODEL=aion-labs/aion-1.0-mini
# THOUGHT_FORK_API_KEY=your-aionlabs-api-key-here


# ------------------------------------------
# OPTION 5: NVIDIA (Cloud)
# ------------------------------------------
# THOUGHT_FORK_API_BASE=https://integrate.api.nvidia.com/v1
# THOUGHT_FORK_MODEL=google/diffusiongemma-26b-a4b-it
# THOUGHT_FORK_SYNTHESIS_MODEL=google/diffusiongemma-26b-a4b-it
# THOUGHT_FORK_SELECTOR_MODEL=google/diffusiongemma-26b-a4b-it
# THOUGHT_FORK_API_KEY=your-nvidia-api-key-here
